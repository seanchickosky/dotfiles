# Bootstrap packages on first shell (DOTFILES_DIR set by .zshrc)
if [[ ! -f "$DOTFILES_DIR/.bootstrapped" ]]; then
  "$DOTFILES_DIR/install.sh"
fi

# oh-my-zsh (sets up completion, themes — must load before shared config)
export ZSH="$HOME/.oh-my-zsh"
[[ -f "$ZSH/oh-my-zsh.sh" ]] && source "$ZSH/oh-my-zsh.sh"

# Keep claude-code up to date (npm available in shell but not during provisioning)
if command -v npm &>/dev/null; then
  npm update -g @anthropic-ai/claude-code &>/dev/null &
fi

# Claude with auto-accept but restricted network/git tools
alias claude='claude --dangerously-skip-permissions --disallowedTools "Bash(git:*) Bash(curl:*) Bash(wget:*)"'
