# Bootstrap packages on first shell (DOTFILES_DIR set by .zshrc)
if [[ ! -f "$DOTFILES_DIR/.bootstrapped" ]]; then
  "$DOTFILES_DIR/install.sh"
fi

# oh-my-zsh (sets up completion, themes — must load before shared config)
export ZSH="$HOME/.oh-my-zsh"
[[ -f "$ZSH/oh-my-zsh.sh" ]] && source "$ZSH/oh-my-zsh.sh"

# Keep claude-code up to date
command -v claude &>/dev/null && claude update &>/dev/null &

export CLAUDE_CODE_NO_FLICKER=1

# Claude with auto-accept but restricted destructive git operations
alias claude='claude --dangerously-skip-permissions --remote-control --disallowedTools "Bash(git push*) Bash(git rebase*) Bash(git reset --hard*) Bash(git force-push*) Bash(git push --force*) Bash(git push -f*) Bash(git commit --amend*) Bash(git filter-branch*) Bash(git reflog expire*) Bash(gt submit*) Bash(gt stack submit*) Bash(gt downstack submit*) Bash(gt upstack submit*)"'
